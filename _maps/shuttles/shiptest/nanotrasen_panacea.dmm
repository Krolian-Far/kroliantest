/obj/machinery/atmospherics/pipe/simple/dark/hidden,
/obj/item/paper{
	name = "paper - Ambulance linking";
	text = "Hello! Thank you for boarding a Panacea-class and forwarding medical care on the frontier! Now, your docked ambulance may require re-linkage due to connection decay from the interference of bluespace drives. No worry, I am here to help. <br> <br> First, grab the hub into your multitool. <br> Next, link it to your relay on board, since it's right there. <br> Now, run down to the relay on the ambulance and link it! Your medical teams off on missions will no longer lose contact with you, or at the very least, each other. <br> <br> Congratulations, you have successfully linked your ambulance to the telecommunications on board! Pat yourself on the back and continue on your day without worry that your ambulance could have been hijacked without your knowledge.";
	pixel_x = -4;
	pixel_y = 3;
	info = "Hello! Thank you for boarding a Panacea-class and forwarding medical care on the frontier! Now, your docked ambulance may require re-linkage due to connection decay from the interference of bluespace drives. No worry, I am here to help. <br> <br> First, grab the hub into your multitool. <br> Next, link it to your relay on board, since it's right there. <br> Now, run down to the relay on the ambulance and link it! Your medical teams off on missions will no longer lose contact with you, or at the very least, each other. <br> <br> Congratulations, you have successfully linked your ambulance to the telecommunications on board! Pat yourself on the back and continue on your day without worry that your ambulance could have been hijacked without your knowledge."
	},
